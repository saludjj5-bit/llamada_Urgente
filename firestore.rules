rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's unique identifier.
    //   - email: string (required) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - role: string (required, ['admin', 'admin2', 'usuario']) - The user's role.
    //   - groupId: string (optional) - The ID of the group the user belongs to.
    //   - createdAt: timestamp (required) - When the user profile was created.
    //
    // Collection: groups
    // Document ID: {groupId}
    // Fields:
    //   - id: string (required) - The unique identifier for the group.
    //   - name: string (required) - The name of the group.
    //   - description: string (optional) - A brief description of the group.
    //   - createdAt: timestamp (required) - When the group was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "saludjj5@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isAdmin2() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin2';
    }

    function getUserGroup() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    function isUsuario() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'usuario';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.email is string &&
             data.role in ['admin', 'admin2', 'usuario'] &&
             (data.get('isTalking', null) == null || data.isTalking is bool) &&
             data.createdAt is timestamp;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt']) &&
             data.id is string &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() < 100 &&
             (data.get('description', null) == null || data.description is string) &&
             (data.get('parentGroupId', null) == null || data.parentGroupId is string) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow users to get their own doc or admins to get any doc
      allow get: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        isAdmin2() ||
        (resource != null && resource.data.email == request.auth.token.email)
      );

      // Allow listing if admin or if filtered by own email
      allow list: if isAuthenticated() && (
        isAdmin() || 
        isAdmin2() ||
        (resource != null && resource.data.email == request.auth.token.email)
      );
      
      // Only admins can create users for others. 
      // Users can create their own profile if it matches their email (for linking).
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || 
        (isAdmin2() && request.resource.data.groupId == getUserGroup()) ||
        (isOwner(userId) && request.resource.data.email == request.auth.token.email)
      );
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() ||
        (isAdmin2() && resource.data.groupId == getUserGroup() && request.resource.data.groupId == getUserGroup()) ||
        (isOwner(userId) && request.resource.data.role == resource.data.role)
      );

      // Only admins can delete users, or users can delete their own pre-authorized doc by email
      allow delete: if isAdmin() || 
                    (isAdmin2() && resource.data.groupId == getUserGroup()) ||
                    (isAuthenticated() && resource.data.email == request.auth.token.email);
    }

    match /groups/{groupId} {
      // All authenticated users can read groups
      allow read: if isAuthenticated();
      
      // Only admins or admin2 can manage groups
      // Admin2 can only create/update/delete if parentGroupId matches their group
      allow create: if (isAdmin() || (isAdmin2() && request.resource.data.parentGroupId == getUserGroup())) && isValidGroup(request.resource.data);
      allow update: if (isAdmin() || (isAdmin2() && resource.data.parentGroupId == getUserGroup() && request.resource.data.parentGroupId == getUserGroup())) && isValidGroup(request.resource.data);
      allow delete: if isAdmin() || (isAdmin2() && resource.data.parentGroupId == getUserGroup());
    }
  }
}
